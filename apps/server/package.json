  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "@trpc/server": "^11.18.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "vitest": "^4.1.10"
  }
